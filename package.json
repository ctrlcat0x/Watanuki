{
  "name": "watanuki",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bash scripts/build-packages.sh",
    "build:turbo": "turbo run build",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "dev:docs": "turbo run dev --filter=docs",
    "lint": "turbo run lint",
    "publish:packages": "bash scripts/publish-packages.sh",
    "test": "turbo run test --continue",
    "types:check": "turbo run types:check --continue"
  },
  "devDependencies": {
    "oxlint": "^1.71.0",
    "rimraf": "^6.1.3",
    "turbo": "2.9.18",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">= 20.0.0"
  },
  "packageManager": "pnpm@11.5.3"
}
