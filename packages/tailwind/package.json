{
  "name": "@watanuki/tailwind",
  "version": "0.0.5",
  "description": "The Tailwind CSS utils for Watanuki UI.",
  "keywords": [
    "Docs",
    "Watanuki"
  ],
  "homepage": "https://watanuki.dev",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:ctrlcat0x/Watanuki",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./typography": "./dist/typography/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "devDependencies": {
    "@fastify/deepmerge": "^3.2.1",
    "@types/node": "^26.0.0",
    "postcss-selector-parser": "^7.1.4",
    "tailwindcss": "^4.3.1",
    "tsconfig": "workspace:*",
    "tsdown": "0.22.3"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "inlinedDependencies": {
    "@fastify/deepmerge": "3.2.1",
    "cssesc": "3.0.0",
    "postcss-selector-parser": "7.1.4",
    "util-deprecate": "1.0.2"
  }
}
