{
  "name": "@watanuki/theme",
  "version": "0.1.0",
  "description": "Watanuki styles (layout) and themes (colors)",
  "license": "MIT",
  "repository": "github:ctrlcat0x/Watanuki",
  "publishConfig": {
    "access": "public"
  },
  "files": ["css", "dist"],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./config": "./dist/config.js",
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./styles.css": {
      "style": "./css/styles.css",
      "default": "./css/styles.css"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "cnfast": "^0.0.8",
    "lucide-react": "^1.21.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "rimraf": "^6.1.3",
    "tsconfig": "workspace:*",
    "tsdown": "0.22.3",
    "typescript": "^6.0.3"
  }
}
